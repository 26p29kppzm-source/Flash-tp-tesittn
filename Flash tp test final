        elseif labelText == "Slow Fall" then
            ToggleSlowFall(state)
        elseif labelText == "Anti Bee & Disco" then
            ToggleAntiBee(state)
        elseif labelText == "AP Spammer" then
            ToggleAPSpammer(state)
        elseif labelText == "Inf Jump" then
            if state then startInfJump() else stopInfJump() end
        end
        if extraAction then extraAction(state) end
    end)
    return returnTable
end

