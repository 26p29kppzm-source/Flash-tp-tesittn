local function loadSettings()
    pcall(function()
        if isfile and isfile(savePath) then
            local content = readfile(savePath)
            local decoded = HttpService:JSONDecode(content)
            if decoded.sliderValue then sliderValue = math.clamp(decoded.sliderValue, 0.01, 1.00) end
            if decoded.laggerPower then laggerPower = math.clamp(decoded.laggerPower, 0, 100) end
            if decoded.speedBoostMax then speedBoostMax = math.clamp(decoded.speedBoostMax, 16, 60) end
            if decoded.targetFovValue then targetFovValue = math.clamp(decoded.targetFovValue, 30, 120) end
            if decoded.decorationTransparencyAmount then decorationTransparencyAmount = math.clamp(decoded.decorationTransparencyAmount, 0, 1) end
            if decoded.decorationEnabled ~= nil then decorationEnabled = decoded.decorationEnabled end
            if decoded.currentTheme then currentTheme = decoded.currentTheme end
            
            if decoded.autoPotion ~= nil then toggleStates["Auto Potion"] = decoded.autoPotion end
            if decoded.speedBoost ~= nil then toggleStates["Speed Boost"] = decoded.speedBoost end
            if decoded.laggerOnSteal ~= nil then toggleStates["Lagger on Steal"] = decoded.laggerOnSteal end
            if decoded.fovToggle ~= nil then toggleStates["Camera Move"] = decoded.fovToggle end
            if decoded.resetToggle ~= nil then toggleStates["Reset"] = decoded.resetToggle end
            if decoded.rejoinToggle ~= nil then toggleStates["Rejoin"] = decoded.rejoinToggle end
            if decoded.kickToggle ~= nil then toggleStates["Kick"] = decoded.kickToggle end
            if decoded.tpDownToggle ~= nil then toggleStates["TP Down Button"] = decoded.tpDownToggle end
            if decoded.dropToggle ~= nil then toggleStates["Drop Button"] = decoded.dropToggle end
            if decoded.modelTransparency ~= nil then toggleStates["Transparency"] = decoded.modelTransparency end
            if decoded.antiRagdoll ~= nil then toggleStates["Anti Ragdoll"] = decoded.antiRagdoll end
            if decoded.kickOnSteal ~= nil then toggleStates["Kick on Steal"] = decoded.kickOnSteal end
            if decoded.slowFall ~= nil then toggleStates["Slow Fall"] = decoded.slowFall end
            if decoded.antiBee ~= nil then toggleStates["Anti Bee & Disco"] = decoded.antiBee end
            if decoded.apSpammer ~= nil then toggleStates["AP Spammer"] = decoded.apSpammer end
            if decoded.infJump ~= nil then toggleStates["Inf Jump"] = decoded.infJump end

            if decoded.alignKey then alignKey = Enum.KeyCode[decoded.alignKey] or Enum.KeyCode.V end
            if decoded.resetKeybind then resetKeybind = Enum.KeyCode[decoded.resetKeybind] or Enum.KeyCode.Z end
            if decoded.rejoinKeybind then rejoinKeybind = Enum.KeyCode[decoded.rejoinKeybind] or Enum.KeyCode.X end
            if decoded.kickKeybind then kickKeybind = Enum.KeyCode[decoded.kickKeybind] or Enum.KeyCode.C end
            if decoded.tpDownKeybind then tpDownKeybind = Enum.KeyCode[decoded.tpDownKeybind] or Enum.KeyCode.P end
            if decoded.dropKeybind then dropKeybind = Enum.KeyCode[decoded.dropKeybind] or Enum.KeyCode.U end

            if decoded.modelTransparencyValue then TARGET_TRANSPARENCY = math.clamp(decoded.modelTransparencyValue, 0, 1) end
        end
    end)
    if decorationEnabled then setDecorationEnabled(true) end
    if toggleStates["Transparency"] then startTransparency() end
end

