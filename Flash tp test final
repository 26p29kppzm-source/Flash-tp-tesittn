        local dt = RunService.RenderStepped:Wait()
        tickCount = tickCount + dt
        if currentTheme == "Galaxy" then
            local newRotation = (tickCount * 45) % 360
            local newThickness = 1.3 + math.sin(tickCount * 3.5) * 0.25
            for _, grad in ipairs(gradientsToRotate) do
                if grad and grad.Parent then
                    grad.Rotation = newRotation
                    grad.Parent.Thickness = newThickness
                end
            end
        end
    end
end)

local function cycleTheme()
    local themeList = {"White", "Red", "Blue", "Yellow", "Green", "Pink", "Purple", "Dark", "Galaxy"}
    local idx = 1
    for i, t in ipairs(themeList) do
        if t == currentTheme then idx = i break end
    end
    idx = (idx % #themeList) + 1
    currentTheme = themeList[idx]
    updateAllTheme()
    saveSettings()
end

