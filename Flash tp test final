            bindingDropKey = false
            if dropToggleUI and dropToggleUI.BindBtn then dropToggleUI.BindBtn.Text = "[" .. dropKeybind.Name .. "]" end
            saveSettings()
        end
        return
    end
    if input.KeyCode == alignKey then
        ExecuteAlign()
    elseif input.KeyCode == resetKeybind then
        instantReset()
