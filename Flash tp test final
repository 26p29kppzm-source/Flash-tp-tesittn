local _wfConns = {}
local _wfActive = false
local function stopWalkFling()
    _wfActive = false
    for _, c in ipairs(_wfConns) do
        if typeof(c) == "RBXScriptConnection" then c:Disconnect()
        elseif typeof(c) == "thread" then pcall(task.cancel, c) end
    end
    _wfConns = {}
end
local function startWalkFling()
    stopWalkFling()
    _wfActive = true
    table.insert(_wfConns, RunService.Stepped:Connect(function()
        if not _wfActive then return end
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                for _, part in ipairs(p.Character:GetChildren()) do
                    if part:IsA("BasePart") then part.CanCollide = false end
                end
            end
        end
    end))
    local co = coroutine.create(function()
        while _wfActive do
            RunService.Heartbeat:Wait()
            local char = LocalPlayer.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if not root then continue end
            local vel = root.Velocity
            root.Velocity = vel * 10000 + Vector3.new(0, 10000, 0)
            RunService.RenderStepped:Wait()
            if root and root.Parent then root.Velocity = vel end
            RunService.Stepped:Wait()
            if root and root.Parent then root.Velocity = vel + Vector3.new(0, 0.1, 0) end
        end
    end)
    coroutine.resume(co)
    table.insert(_wfConns, co)
end

local function runTPDown()
    task.spawn(function()
        pcall(function()
            local c = LocalPlayer.Character; if not c then return end
            local hrp = c:FindFirstChild("HumanoidRootPart"); if not hrp then return end
            local hum = c:FindFirstChildOfClass("Humanoid"); if not hum then return end
            local rp = RaycastParams.new()
            rp.FilterDescendantsInstances = {c}
            rp.FilterType = Enum.RaycastFilterType.Exclude
            local hit = Workspace:Raycast(hrp.Position, Vector3.new(0, -500, 0), rp)
            if hit then
                hrp.AssemblyLinearVelocity = Vector3.zero
                hrp.AssemblyAngularVelocity = Vector3.zero
                local hh = hum.HipHeight or 2
                local hy = hrp.Size.Y / 2
                hrp.CFrame = CFrame.new(hit.Position.X, hit.Position.Y + hh + hy + 0.1, hit.Position.Z)
            end
        end)
    end)
end

-- ==================== THEME SYSTEM ====================
local WHITE = Color3.fromRGB(255, 255, 255)

local themeColors = {
    White = Color3.fromRGB(255, 255, 255),
    Red = Color3.fromRGB(255, 60, 60),
    Blue = Color3.fromRGB(60, 120, 255),
    Yellow = Color3.fromRGB(255, 220, 60),
    Green = Color3.fromRGB(60, 255, 100),
    Pink = Color3.fromRGB(255, 100, 200),
    Purple = Color3.fromRGB(180, 60, 255),
    Dark = Color3.fromRGB(180, 180, 180),
    Galaxy = Color3.fromRGB(110, 120, 255)
}

local gradientsToRotate = {}

local function getThemeColor()
    return themeColors[currentTheme] or WHITE
end

local function applyThemeToElement(elem, isStroke)
    if not elem then return end
    local color = getThemeColor()
    if isStroke then
        elem.Color = color
    elseif elem:IsA("TextLabel") or elem:IsA("TextButton") or elem:IsA("TextBox") then
        elem.TextColor3 = color
    end
end

local function updateAllTheme()
    local screen = ScreenGui
    if not screen then return end
    for _, desc in ipairs(screen:GetDescendants()) do
        if desc:IsA("UIStroke") then
            applyThemeToElement(desc, true)
        elseif (desc:IsA("TextLabel") or desc:IsA("TextButton") or desc:IsA("TextBox")) and desc.Name ~= "CenterWatermark" then
            applyThemeToElement(desc, false)
        end
    end
    if APScreenGui and APScreenGui.Parent then
        for _, desc in ipairs(APScreenGui:GetDescendants()) do
            if desc:IsA("UIStroke") then
                applyThemeToElement(desc, true)
            elseif desc:IsA("TextLabel") or desc:IsA("TextButton") then
                applyThemeToElement(desc, false)
            end
        end
    end
end

local function addSleekStroke(frame)
    local stroke = Instance.new("UIStroke")
    stroke.Thickness = 1.5
    stroke.Color = getThemeColor()
    stroke.Transparency = 0.4
    stroke.Parent = frame
    if currentTheme == "Galaxy" then
        local strokeGrad = Instance.new("UIGradient")
        strokeGrad.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(110, 120, 255)),
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255, 110, 180)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(110, 120, 255))
        })
        strokeGrad.Parent = stroke
        table.insert(gradientsToRotate, strokeGrad)
    end
    return stroke
end

