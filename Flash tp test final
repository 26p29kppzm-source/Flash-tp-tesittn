local function isKeyValid()
    if not isfile or not isfile(KEY_SAVE_FILE) then return false end
    local success, data = pcall(function()
        return HttpService:JSONDecode(readfile(KEY_SAVE_FILE))
    end)
    if not success or not data.timestamp then return false end
    return (os.time() - data.timestamp) < 86400 -- 24 hours
end

local function saveKeySuccess()
    if writefile then
        pcall(function()
            writefile(KEY_SAVE_FILE, HttpService:JSONEncode({timestamp = os.time()}))
        end)
    end
end

