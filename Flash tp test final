-- ==================== AUTO KICK ON STEAL ====================
local autoKickConnections = {}

local function startAutoKickAfterSteal()
    if #autoKickConnections > 0 then return end
    
    local keyword = "you stole"
    local kickMessage = "You stole brainrot!"
    
    local function hasKeyword(text)
        if typeof(text) ~= "string" then return false end
        return string.find(string.lower(text), keyword) ~= nil
    end
    
    local function kickPlayer()
        pcall(function()
            LocalPlayer:Kick(kickMessage)
        end)
    end

    local function scanGuiObjects(parent)
        for _, obj in ipairs(parent:GetDescendants()) do
            if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
                if hasKeyword(obj.Text) then 
                    kickPlayer()
                    return true 
                end
                local conn = obj:GetPropertyChangedSignal("Text"):Connect(function()
                    if hasKeyword(obj.Text) then 
                        kickPlayer() 
                    end
                end)
                table.insert(autoKickConnections, conn)
            end
        end
        return false
    end

    local function setupGuiWatcher(gui)
        local conn = gui.DescendantAdded:Connect(function(desc)
            if desc:IsA("TextLabel") or desc:IsA("TextButton") or desc:IsA("TextBox") then
                if hasKeyword(desc.Text) then 
                    kickPlayer() 
                end
                local conn2 = desc:GetPropertyChangedSignal("Text"):Connect(function()
                    if hasKeyword(desc.Text) then 
                        kickPlayer() 
                    end
                end)
                table.insert(autoKickConnections, conn2)
            end
        end)
        table.insert(autoKickConnections, conn)
    end

    for _, gui in ipairs(PlayerGui:GetChildren()) do 
        setupGuiWatcher(gui) 
    end
    
    local childConn = PlayerGui.ChildAdded:Connect(function(gui)
        setupGuiWatcher(gui)
        scanGuiObjects(gui)
    end)
    table.insert(autoKickConnections, childConn)

    scanGuiObjects(PlayerGui)
end

local function stopAutoKickAfterSteal()
    for _, conn in ipairs(autoKickConnections) do 
        pcall(function() conn:Disconnect() end) 
    end
    autoKickConnections = {}
end

