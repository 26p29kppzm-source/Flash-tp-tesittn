            TweenService:Create(knob, t, {Position = UDim2.new(0, 2, 0.5, -6.5)}):Play()
            TweenService:Create(toggleStroke, t, {Transparency = 0.45}):Play()
        end
        saveSettings()
        if isPureUi then
            if extraAction then extraAction(state) end
            return
        end
        if labelText == "Speed Boost" then
            if state then enableSpeedBoost() else disableSpeedBoost() end
        elseif labelText == "Camera Move" then
            if state then enableFovChanger() else disableFovChanger() end
        elseif labelText == "Transparency" then
            if state then startTransparency() else stopTransparency() end
        elseif labelText == "Anti Ragdoll" then
            if state then startAntiRagdoll() else stopAntiRagdoll() end
        elseif labelText == "Kick on Steal" then
