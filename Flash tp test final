        knob.Position = UDim2.new(1, -15, 0.5, -6.5)
        toggleStroke.Transparency = 0.15
    end

    btn.MouseButton1Click:Connect(function()
        state = not state
        toggleStates[labelText] = state
        local t = TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
        if state then
            TweenService:Create(btn, t, {BackgroundColor3 = Color3.fromRGB(55, 55, 55)}):Play()
            TweenService:Create(knob, t, {Position = UDim2.new(1, -15, 0.5, -6.5)}):Play()
            TweenService:Create(toggleStroke, t, {Transparency = 0.15}):Play()
        else
